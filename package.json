{
  "name": "nuve-store",
  "version": "1.0.0",
  "description": "NUVÉ E-commerce — fullstack on Render",
  "main": "backend/src/index.js",
  "engines": { "node": ">=18" },
  "scripts": {
    "start":       "node backend/src/index.js",
    "dev":         "nodemon backend/src/index.js",
    "build": "npm run db:migrate && npm run db:seed",
    "db:migrate":  "node backend/src/db/migrate.js",
    "db:seed":     "node backend/src/db/seed.js"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "pg":                 "^8.11.3",
    "uuid":               "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
